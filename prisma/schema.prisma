  estado               String       @default("Activa", map: "DF__ZonasRieg__estad__7D439ABD") @db.NVarChar(20)
  tipo_cultivo         String?      @db.NVarChar(100)
  area_m2              Decimal?     @db.Decimal(10, 2)
  profundidad_riego_cm Decimal?     @db.Decimal(5, 2)
  caudal_litros_min    Decimal?     @db.Decimal(10, 2)
  metodo_riego         String?      @db.NVarChar(50)
  fecha_creacion       DateTime?    @default(now(), map: "DF__ZonasRieg__fecha__7E37BEF6") @db.DateTime
  observaciones        String?      @db.NVarChar(Max)
  Riegos               Riegos[]
  Invernaderos         Invernaderos @relation(fields: [id_invernadero], references: [id_invernadero], onUpdate: NoAction, map: "FK_Zonas_Invernaderos")

  @@index([id_invernadero], map: "IX_ZonasRiego_id_invernadero")
}
