generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Alertas {
  id_alerta          Int       @id(map: "PK__Alertas__1227953E2CD5C2CA") @default(autoincrement())
  id_sensor          Int
  tipo_alerta        String    @db.NVarChar(100)
  valor_detectado    Decimal?  @db.Decimal(10, 2)
  fecha_hora         DateTime  @default(now(), map: "DF__Alertas__fecha_h__6A30C649") @db.DateTime
  estado             String    @db.NVarChar(20)
  umbral_min         Decimal?  @db.Decimal(10, 2)
  umbral_max         Decimal?  @db.Decimal(10, 2)
  nivel              String?   @db.NVarChar(20)
  accion_recomendada String?   @db.NVarChar(200)
  atendida_por       Int?
  fecha_atencion     DateTime? @db.DateTime
  Sensores           Sensores  @relation(fields: [id_sensor], references: [id_sensor], onUpdate: NoAction, map: "FK_Alertas_Sensores")
}

model AplicacionesFertilizantes {
  id_aplicacion     Int               @id(map: "PK__Aplicaci__D3D4F74A8E905922") @default(autoincrement())
  id_plan           Int
  fecha_aplicacion  DateTime          @default(now(), map: "DF__Aplicacio__fecha__6B24EA82") @db.DateTime
  cantidad_aplicada String            @db.NVarChar(50)
  aplicado_por      Int?
  notas             String?           @db.NVarChar(Max)
  PlanFertilizacion PlanFertilizacion @relation(fields: [id_plan], references: [id_plan], onUpdate: NoAction, map: "FK_Aplicaciones_PlanFert")
  Usuarios          Usuarios?         @relation(fields: [aplicado_por], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction, map: "FK_Aplicaciones_Usuario")
}

model BitacoraMantenimiento {
  id_bitacora        Int             @id(map: "PK__Bitacora__7E4268B025C2D523") @default(autoincrement())
  id_dispositivo     Int
  descripcion_evento String          @db.NVarChar(Max)
  severidad          String          @db.NVarChar(20)
  fecha_evento       DateTime        @default(now(), map: "DF__BitacoraM__fecha__6C190EBB") @db.DateTime
  registrado_por     Int
  notas              String?         @db.NVarChar(Max)
  DispositivosIoT    DispositivosIoT @relation(fields: [id_dispositivo], references: [id_dispositivo], onUpdate: NoAction, map: "FK_Bitacora_Dispositivo")
  Usuarios           Usuarios        @relation(fields: [registrado_por], references: [id_usuario], onUpdate: NoAction, map: "FK_Bitacora_Usuario")
}

model ComandosIoT {
  id_comando      Int             @id(map: "PK__Comandos__6D6D173F026ADB63") @default(autoincrement())
  id_dispositivo  Int
  comando         String          @db.NVarChar(100)
  parametros      String?         @db.NVarChar(Max)
  enviado_por     Int?
  fecha_envio     DateTime        @default(now(), map: "DF__ComandosI__fecha__6D0D32F4") @db.DateTime
  estado          String          @default("Pendiente", map: "DF__ComandosI__estad__6E01572D") @db.NVarChar(20)
  DispositivosIoT DispositivosIoT @relation(fields: [id_dispositivo], references: [id_dispositivo], onUpdate: NoAction, map: "FK_Comandos_Dispositivo")
  Usuarios        Usuarios?       @relation(fields: [enviado_por], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction, map: "FK_Comandos_Usuarios")
}

model ConfiguracionesSistema {
  id_config          Int       @id(map: "PK__Configur__8F0A1FB246A76CA6") @default(autoincrement())
  id_empresa         Int
  parametro          String    @db.NVarChar(100)
  valor              String    @db.NVarChar(100)
  descripcion        String?   @db.NVarChar(Max)
  fecha_creacion     DateTime  @default(now(), map: "DF__Configura__fecha__6EF57B66") @db.DateTime
  creado_por         Int
  fecha_modificacion DateTime? @db.DateTime
  Empresas           Empresas  @relation(fields: [id_empresa], references: [id_empresa], onUpdate: NoAction, map: "FK_Config_Empresa")
  Usuarios           Usuarios  @relation(fields: [creado_por], references: [id_usuario], onUpdate: NoAction, map: "FK_Config_Usuarios")
}

model ConfiguracionSistema {
  ConfigID          Int       @id(map: "PK__Configur__C3BC333C809A256F") @default(autoincrement())
  Clave             String    @unique(map: "UQ__Configur__E8181E11E4600F14") @db.NVarChar(100)
  Valor             String    @db.NVarChar(500)
  Descripcion       String?   @db.NVarChar(500)
  Categoria         String?   @db.NVarChar(50)
  FechaModificacion DateTime? @default(now(), map: "DF__Configura__Fecha__6FE99F9F")
}

model ControlPlagas {
  id_plaga         Int            @id(map: "PK__ControlP__04D45885A1F82867") @default(autoincrement())
  id_detalle       Int
  tipo_plaga       String?        @db.NVarChar(100)
  producto_usado   String?        @db.NVarChar(100)
  dosis            String?        @db.NVarChar(50)
  fecha_aplicacion DateTime       @default(now(), map: "DF__ControlPl__fecha__70DDC3D8") @db.DateTime
  notas            String?        @db.NVarChar(Max)
  CultivoDetalle   CultivoDetalle @relation(fields: [id_detalle], references: [id_detalle], onUpdate: NoAction, map: "FK_Plagas_CultivoDetalle")
}

model CultivoDetalle {
  id_detalle              Int                 @id(map: "PK__CultivoD__4F1332DE165A30D7") @default(autoincrement())
  id_cultivo              Int
  fecha_siembra           DateTime            @db.Date
  fecha_cosecha_estimada  DateTime?           @db.Date
  variedad                String?             @db.NVarChar(100)
  tiempo_germinacion_dias Int?
  tiempo_crecimiento_dias Int?
  tiempo_cosecha_dias     Int?
  notas                   String?             @db.NVarChar(Max)
  ControlPlagas           ControlPlagas[]
  Cultivos                Cultivos            @relation(fields: [id_cultivo], references: [id_cultivo], onUpdate: NoAction, map: "FK_Detalle_Cultivo")
  EtapasCultivo           EtapasCultivo[]
  PlanFertilizacion       PlanFertilizacion[]
}

model Cultivos {
  id_cultivo     Int              @id(map: "PK__Cultivos__5E52C571F360A377") @default(autoincrement())
  nombre         String           @db.NVarChar(100)
  variedad       String?          @db.NVarChar(100)
  id_invernadero Int
  fecha_siembra  DateTime?        @db.Date
  CultivoDetalle CultivoDetalle[]
  Invernaderos   Invernaderos     @relation(fields: [id_invernadero], references: [id_invernadero], onUpdate: NoAction, map: "FK_Cultivos_Invernaderos")
}

model DispositivosIoT {
  id_dispositivo        Int                     @id(map: "PK__Disposit__FD7B94E53D46A882") @default(autoincrement())
  id_invernadero        Int
  nombre                String                  @db.NVarChar(100)
  tipo                  String                  @db.NVarChar(50)
  firmware_version      String?                 @db.NVarChar(50)
  ip_local              String?                 @db.NVarChar(50)
  estado                String                  @default("Activo", map: "DF__Dispositi__estad__71D1E811") @db.NVarChar(20)
  ultimo_reporte        DateTime?               @db.DateTime
  BitacoraMantenimiento BitacoraMantenimiento[]
  ComandosIoT           ComandosIoT[]
  Invernaderos          Invernaderos            @relation(fields: [id_invernadero], references: [id_invernadero], onUpdate: NoAction, map: "FK_Dispositivos_Invernaderos")
  IoTLog                IoTLog[]
  MantenimientoEquipos  MantenimientoEquipos[]
  Sensores              Sensores[]
}

model Empresas {
  id_empresa             Int                      @id(map: "PK__Empresas__4A0B7E2C3F71B32C") @default(autoincrement())
  nombre                 String                   @db.NVarChar(150)
  rnc                    String?                  @db.NVarChar(20)
  direccion              String?                  @db.NVarChar(200)
  telefono               String?                  @db.NVarChar(20)
  correo                 String?                  @db.NVarChar(100)
  estado                 String                   @default("Activa", map: "DF__Empresas__estado__72C60C4A") @db.NVarChar(20)
  fecha_creacion         DateTime                 @default(now(), map: "DF__Empresas__fecha___73BA3083") @db.DateTime
  ConfiguracionesSistema ConfiguracionesSistema[]
  Invernaderos           Invernaderos[]
  TareasProgramadas      TareasProgramadas[]
  Usuarios               Usuarios[]
}

model EtapasCultivo {
  id_etapa       Int            @id(map: "PK__EtapasCu__9927D0E83355C7FC") @default(autoincrement())
  id_detalle     Int
  nombre_etapa   String         @db.NVarChar(100)
  fecha_inicio   DateTime       @db.Date
  fecha_fin      DateTime?      @db.Date
  notas          String?        @db.NVarChar(Max)
  CultivoDetalle CultivoDetalle @relation(fields: [id_detalle], references: [id_detalle], onUpdate: NoAction, map: "FK_Etapas_CultivoDetalle")
}

model Fertilizantes {
  id_fertilizante   Int                 @id(map: "PK__Fertiliz__A15CA36A4442C260") @default(autoincrement())
  nombre            String              @db.NVarChar(100)
  tipo              String              @db.NVarChar(50)
  composicion       String?             @db.NVarChar(200)
  fabricante        String?             @db.NVarChar(100)
  ph                Decimal?            @db.Decimal(4, 2)
  nitrogeno         Decimal?            @db.Decimal(5, 2)
  fosforo           Decimal?            @db.Decimal(5, 2)
  potasio           Decimal?            @db.Decimal(5, 2)
  micronutrientes   String?             @db.NVarChar(200)
  forma_aplicacion  String?             @db.NVarChar(50)
  riesgos           String?             @db.NVarChar(Max)
  fecha_registro    DateTime?           @default(now(), map: "DF__Fertiliza__fecha__74AE54BC") @db.DateTime
  PlanFertilizacion PlanFertilizacion[]
}

model Invernaderos {
  id_invernadero  Int               @id(map: "PK__Invernad__88CCC9F94D11B539") @default(autoincrement())
  id_empresa      Int
  nombre          String            @db.NVarChar(100)
  ubicacion       String?           @db.NVarChar(150)
  superficie_m2   Decimal?          @db.Decimal(10, 2)
  id_usuario      Int?
  Cultivos        Cultivos[]
  DispositivosIoT DispositivosIoT[]
  Empresas        Empresas          @relation(fields: [id_empresa], references: [id_empresa], onUpdate: NoAction, map: "FK_Invernaderos_Empresas")
  Usuarios        Usuarios?         @relation(fields: [id_usuario], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction, map: "FK_Invernaderos_Usuario")
  Reportes        Reportes[]
  Sensores        Sensores[]
  ZonasRiego      ZonasRiego[]

  @@index([id_empresa], map: "IX_Invernaderos_id_empresa")
}

model IoTLog {
  id_log          Int             @id(map: "PK__IoTLog__6CC851FEF52A0FEC") @default(autoincrement())
  id_dispositivo  Int
  tipo_mensaje    String          @db.NVarChar(50)
  payload         String?         @db.NVarChar(Max)
  fecha_evento    DateTime        @default(now(), map: "DF__IoTLog__fecha_ev__75A278F5") @db.DateTime
  estado          String          @db.NVarChar(20)
  DispositivosIoT DispositivosIoT @relation(fields: [id_dispositivo], references: [id_dispositivo], onUpdate: NoAction, map: "FK_IoTLog_Dispositivo")
}

model LecturasSensores {
  id_lectura Int      @id(map: "PK__Lecturas__E96875965F30D9C6") @default(autoincrement())
  id_sensor  Int
  valor      Decimal  @db.Decimal(10, 2)
  unidad     String   @db.NVarChar(10)
  fecha_hora DateTime @default(now(), map: "DF__LecturasS__fecha__76969D2E") @db.DateTime
  Sensores   Sensores @relation(fields: [id_sensor], references: [id_sensor], onUpdate: NoAction, map: "FK_Lecturas_Sensores")

  @@index([id_sensor], map: "IX_LecturasSensores_id_sensor")
}

model MantenimientoEquipos {
  id_mantenimiento      Int             @id(map: "PK__Mantenim__707E5D169ABC4AD9") @default(autoincrement())
  id_dispositivo        Int
  tipo_mantenimiento    String          @db.NVarChar(20)
  descripcion           String?         @db.NVarChar(Max)
  realizado_por         Int
  fecha_mantenimiento   DateTime        @default(now(), map: "DF__Mantenimi__fecha__778AC167") @db.DateTime
  proximo_mantenimiento DateTime?       @db.DateTime
  estado_equipo_post    String          @db.NVarChar(20)
  notas                 String?         @db.NVarChar(Max)
  DispositivosIoT       DispositivosIoT @relation(fields: [id_dispositivo], references: [id_dispositivo], onUpdate: NoAction, map: "FK_Mant_Dispositivo")
  Usuarios              Usuarios        @relation(fields: [realizado_por], references: [id_usuario], onUpdate: NoAction, map: "FK_Mant_Usuario")
}

model PlanFertilizacion {
  id_plan                   Int                         @id(map: "PK__PlanFert__3901EAE387DD0070") @default(autoincrement())
  id_detalle                Int
  id_fertilizante           Int
  dosis                     String                      @db.NVarChar(50)
  frecuencia_dias           Int
  inicio_aplicacion         DateTime                    @db.Date
  fin_aplicacion            DateTime?                   @db.Date
  notas                     String?                     @db.NVarChar(Max)
  AplicacionesFertilizantes AplicacionesFertilizantes[]
  CultivoDetalle            CultivoDetalle              @relation(fields: [id_detalle], references: [id_detalle], onUpdate: NoAction, map: "FK_PlanFert_CultivoDetalle")
  Fertilizantes             Fertilizantes               @relation(fields: [id_fertilizante], references: [id_fertilizante], onUpdate: NoAction, map: "FK_PlanFert_Fertilizantes")
}

model Reportes {
  id_reporte     Int          @id(map: "PK__Reportes__87E4F5CBA5C044EF") @default(autoincrement())
  id_invernadero Int
  tipo           String       @db.NVarChar(50)
  descripcion    String?      @db.NVarChar(Max)
  fecha_generado DateTime     @default(now(), map: "DF__Reportes__fecha___787EE5A0") @db.DateTime
  generado_por   Int?
  rango_inicio   DateTime?    @db.DateTime
  rango_fin      DateTime?    @db.DateTime
  formato        String?      @db.NVarChar(20)
  ruta_archivo   String?      @db.NVarChar(200)
  estado         String?      @db.NVarChar(20)
  Invernaderos   Invernaderos @relation(fields: [id_invernadero], references: [id_invernadero], onUpdate: NoAction, map: "FK_Reportes_Invernaderos")
}

model Riegos {
  id_riego       Int        @id(map: "PK__Riegos__41B02AA6731BFB1A") @default(autoincrement())
  id_zona        Int
  id_usuario     Int?
  tipo           String     @db.NVarChar(20)
  duracion_min   Int
  volumen_litros Decimal?   @db.Decimal(10, 2)
  fecha_inicio   DateTime   @default(now(), map: "DF__Riegos__fecha_in__797309D9") @db.DateTime
  fecha_fin      DateTime?  @db.DateTime
  Usuarios       Usuarios?  @relation(fields: [id_usuario], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction, map: "FK_Riegos_Usuarios")
  ZonasRiego     ZonasRiego @relation(fields: [id_zona], references: [id_zona], onUpdate: NoAction, map: "FK_Riegos_Zonas")
}

model Roles {
  RolID       Int      @id(map: "PK__Roles__F92302D17C356B14") @default(autoincrement())
  Nombre      String   @unique(map: "UQ__Roles__75E3EFCFCBBB21BE") @db.NVarChar(50)
  Descripcion String?  @db.NVarChar(200)
  Permisos    String?  @db.NVarChar(Max)
  Activo      Boolean? @default(true, map: "DF__Roles__Activo__7A672E12")
}

model Sensores {
  id_sensor         Int                @id(map: "PK__Sensores__ADD5F94D565FA8CF") @default(autoincrement())
  id_invernadero    Int
  id_dispositivo    Int?
  tipo              String             @db.NVarChar(30)
  modelo            String?            @db.NVarChar(50)
  estado            String             @db.NVarChar(20)
  marca             String?            @db.NVarChar(50)
  rango_min         Decimal?           @db.Decimal(10, 2)
  rango_max         Decimal?           @db.Decimal(10, 2)
  unidad_medida     String?            @db.NVarChar(10)
  precision         Decimal?           @db.Decimal(5, 2)
  fecha_instalacion DateTime?          @db.Date
  ubicacion_fisica  String?            @db.NVarChar(100)
  ultimo_calibrado  DateTime?          @db.Date
  observaciones     String?            @db.NVarChar(Max)
  Alertas           Alertas[]
  LecturasSensores  LecturasSensores[]
  DispositivosIoT   DispositivosIoT?   @relation(fields: [id_dispositivo], references: [id_dispositivo], onDelete: NoAction, onUpdate: NoAction, map: "FK_Sensores_Dispositivos")
  Invernaderos      Invernaderos       @relation(fields: [id_invernadero], references: [id_invernadero], onUpdate: NoAction, map: "FK_Sensores_Invernaderos")

  @@index([id_invernadero], map: "IX_Sensores_id_invernadero")
}

model TareasProgramadas {
  id_tarea          Int      @id(map: "PK__TareasPr__C0ECF707822E0AFC") @default(autoincrement())
  id_empresa        Int
  titulo            String   @db.NVarChar(150)
  descripcion       String?  @db.NVarChar(Max)
  frecuencia        String   @db.NVarChar(20)
  proxima_ejecucion DateTime @db.DateTime
  responsable       Int
  estado            String   @default("Activa", map: "DF__TareasPro__estad__7B5B524B") @db.NVarChar(20)
  Empresas          Empresas @relation(fields: [id_empresa], references: [id_empresa], onUpdate: NoAction, map: "FK_Tareas_Empresas")
  Usuarios          Usuarios @relation(fields: [responsable], references: [id_usuario], onUpdate: NoAction, map: "FK_Tareas_Usuario")
}

model TiposSensor {
  TipoSensorID Int      @id(map: "PK__TiposSen__1BC9C5CE9C4899DC") @default(autoincrement())
  Nombre       String   @db.NVarChar(100)
  Unidad       String?  @db.NVarChar(20)
  RangoMin     Decimal? @db.Decimal(10, 2)
  RangoMax     Decimal? @db.Decimal(10, 2)
  Descripcion  String?  @db.NVarChar(500)
}

model Usuarios {
  id_usuario                Int                         @id(map: "PK__Usuarios__4E3E04AD35F4B3C8") @default(autoincrement())
  id_empresa                Int
  nombre                    String                      @db.NVarChar(100)
  correo                    String                      @unique(map: "UQ__Usuarios__2A586E0B3667EF55") @db.NVarChar(100)
  contrase_a                String                      @map("contraseña") @db.NVarChar(255)
  rol                       String                      @db.NVarChar(20)
  fecha_registro            DateTime                    @default(now(), map: "DF__Usuarios__fecha___7C4F7684") @db.DateTime
  AplicacionesFertilizantes AplicacionesFertilizantes[]
  BitacoraMantenimiento     BitacoraMantenimiento[]
  ComandosIoT               ComandosIoT[]
  ConfiguracionesSistema    ConfiguracionesSistema[]
  Invernaderos              Invernaderos[]
  MantenimientoEquipos      MantenimientoEquipos[]
  Riegos                    Riegos[]
  TareasProgramadas         TareasProgramadas[]
  Empresas                  Empresas                    @relation(fields: [id_empresa], references: [id_empresa], onUpdate: NoAction, map: "FK_Usuarios_Empresas")

  @@index([correo], map: "IX_Usuarios_correo")
}

model ZonasRiego {
  id_zona              Int          @id(map: "PK__ZonasRie__67C936119343D240") @default(autoincrement())
  nombre               String       @db.NVarChar(100)
  id_invernadero       Int
