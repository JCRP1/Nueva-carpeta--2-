# ============================================
# GreenSense - Configuración de Base de Datos
# ============================================
# COPIAR este archivo como .env y personalizar los valores
# NO compartir el .env real (ya está en .gitignore)

# SQL Server Connection
# Formato Prisma: sqlserver://host:puerto;database=db;user=user;password=pass
#
# Si usas instancia nombrada (SQLEXPRESS):
#   sqlserver://TU_PC\\SQLEXPRESS:1433;...
#
# Si usas puerto dinámico (common en SQL Server Express):
#   sqlserver://TU_PC:1433;... (sin instancia, solo puerto)
#
# El usuario y password son los de TU SQL Server local

DATABASE_URL="sqlserver://TU_PC\\SQLEXPRESS:1433;database=GreenSenseDB;user=TU_USUARIO;password=TU_PASSWORD;trustServerCertificate=true"

# JWT Secret (cambiar en producción)
JWT_SECRET=greensense-secret-key-change-in-production-2026
